class Solution:
    def compress(self, chars: List[str]) -> int:
        i = 0
        index = 0

        while i < len(chars):
            current = chars[i]
            count = 0

            while i < len(chars) and chars[i] == current:
                count += 1
                i += 1

            chars[index] = current
            index += 1

            if count > 1:
                for digit in str(count):
                    chars[index] = digit
                    index += 1

        return index
