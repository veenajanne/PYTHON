class Stack:
  def __init__(self):
    self.l=[]
  def push(self,a):
    self.l.append(a)
  def pop(self):
    self.l.pop()
  def display(self):
    b="->".join(map(str,self.l))
    print(b)
  def peek(self):
    print(self.l[-1])

s=Stack()
s.push(100)
s.push(20)
s.push(30)
s.push(40)
s.display()
s.pop()
s.display()
s.peek()
